{
  "version": 2,
  "functions": {
    "api/match.py": {
      "runtime": "@vercel/python@4.3.1"
    },
    "api/tailor.py": {
      "runtime": "@vercel/python@4.3.1"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}